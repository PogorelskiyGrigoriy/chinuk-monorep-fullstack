{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@project/shared": ["../shared/src/index.ts"]
    },
    "resolveJsonModule": true,
    "sourceMap": true
  },
  "include": ["src/**/*", "../shared/src/**/*"]
}